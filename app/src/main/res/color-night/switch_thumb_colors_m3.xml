<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ON state: On Primary -->
    <item android:color="?attr/colorOnPrimary" android:state_checked="true" android:state_enabled="true" />
    
    <!-- OFF state: Original M3 Outline color (Best for Dark Mode) -->
    <item android:color="?attr/colorOutline" android:state_checked="false" android:state_enabled="true" />
    
    <!-- Disabled -->
    <item android:alpha="0.38" android:color="?attr/colorOnSurface" />
</selector>
