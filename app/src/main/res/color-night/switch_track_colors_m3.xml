<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ON state: Primary -->
    <item android:color="?attr/colorPrimary" android:state_checked="true" android:state_enabled="true" />
    
    <!-- OFF state: Original M3 Surface Container Highest (Best for Dark Mode) -->
    <item android:color="?attr/colorSurfaceContainerHighest" android:state_checked="false" android:state_enabled="true" />
    
    <!-- Disabled -->
    <item android:alpha="0.12" android:color="?attr/colorOnSurface" />
</selector>
