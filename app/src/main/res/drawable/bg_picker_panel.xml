<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#EE1A1C1E"
        android:endColor="#F5000000"
        android:type="linear" />
    <!-- Rounded card, not pill — 16dp corners look like a proper floating panel -->
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#26FFFFFF" />
</shape>
