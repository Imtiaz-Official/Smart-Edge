<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 2. INTERACTION SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interaction"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#0DFFFFFF"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Screen Side" android:textColor="@color/text_primary" />
                <RadioGroup
                    android:id="@+id/rgPanelSide"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <RadioButton android:id="@+id/rbRight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Right Side" android:textColor="@color/text_secondary" android:buttonTint="@color/accent_blue" />
                    <RadioButton android:id="@+id/rbLeft" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Left Side" android:textColor="@color/text_secondary" android:buttonTint="@color/accent_blue" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginVertical="16dp" />

                <Switch android:id="@+id/switchGestures" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Edge Swipe Gestures" android:textColor="@color/text_primary" android:thumbTint="@color/accent_blue" />
                <Switch android:id="@+id/switchTapOpen" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Tap Pill to Open" android:textColor="@color/text_primary" android:thumbTint="@color/accent_blue" />
                <Switch android:id="@+id/switchAutoStart" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Auto-start on Boot" android:textColor="@color/text_primary" android:thumbTint="@color/accent_blue" />
                <Switch android:id="@+id/switchHaptic" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Haptic Feedback" android:textColor="@color/text_primary" android:thumbTint="@color/accent_blue" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. APPEARANCE SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#0DFFFFFF"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UI Style Theme" android:textColor="@color/text_primary" />
                <RadioGroup android:id="@+id/rgThemes" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                    <RadioButton android:id="@+id/rbThemeOrigin" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="OriginOS (Rounded)" android:textColor="@color/text_secondary" />
                    <RadioButton android:id="@+id/rbThemeHyper" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="HyperOS (Glass)" android:textColor="@color/text_secondary" />
                    <RadioButton android:id="@+id/rbThemeRealme" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Realme UI" android:textColor="@color/text_secondary" />
                    <RadioButton android:id="@+id/rbThemeRich" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Rich UI (Glow)" android:textColor="@color/text_secondary" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginVertical="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Icon Shape" android:textColor="@color/text_primary" />
                <RadioGroup android:id="@+id/rgIconShape" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                    <RadioButton android:id="@+id/rbShapeCircle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Circle" android:textColor="@color/text_secondary" />
                    <RadioButton android:id="@+id/rbShapeSquircle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Squircle" android:textColor="@color/text_secondary" />
                    <RadioButton android:id="@+id/rbShapeSquare" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Square" android:textColor="@color/text_secondary" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginVertical="16dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Icon Pack" android:textColor="@color/text_primary" />
                        <TextView android:id="@+id/tvCurrentIconPack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="System Default" android:textColor="@color/text_tertiary" android:textSize="12sp" />
                    </LinearLayout>
                    <Button android:id="@+id/btnSelectIconPack" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Change" android:textSize="12sp" android:backgroundTint="#1AFFFFFF" android:textAllCaps="false" app:cornerRadius="8dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginVertical="16dp" />

                <!-- Added back missing sliders -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Panel Opacity" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <SeekBar android:id="@+id/sbOpacity" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="100" android:progressTint="@color/accent_blue" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Corner Radius (Premium)" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <SeekBar android:id="@+id/sbPanelRadius" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="60" android:progress="28" android:progressTint="@color/accent_blue" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. HANDLE SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Handle &amp; Pill"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#0DFFFFFF"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <Switch android:id="@+id/switchShowPill" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Visible Pill Handle" android:textColor="@color/text_primary" android:thumbTint="@color/accent_blue" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Handle Height" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <SeekBar android:id="@+id/sbHandleHeight" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="300" android:progress="80" android:progressTint="@color/accent_blue" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Trigger Area Width" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <SeekBar android:id="@+id/sbHandleWidth" android:layout_width="match_parent" android:layout_height="wrap_content" android:min="24" android:max="100" android:progress="24" android:progressTint="@color/accent_blue" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Vertical Position (Premium)" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <SeekBar android:id="@+id/sbHandleOffset" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="200" android:progress="100" android:progressTint="@color/accent_blue" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 5. PREMIUM DASHBOARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPremium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#1A4A9EFF"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:id="@+id/tvPremiumStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Premium Dashboard" android:textColor="#FFFFFF" android:textStyle="bold" />
                
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="12dp" />

                <!-- Master Toggle for Custom Accent -->
                <Switch android:id="@+id/switchUseCustomAccent" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Use Custom Accent Color" android:textColor="#FFFFFF" android:thumbTint="#FFFFFF" android:layout_marginBottom="16dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Accent Color" android:textColor="#FFFFFF" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickAccent"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner50"
                        android:backgroundTint="@color/accent_blue"
                        app:strokeColor="#4DFFFFFF"
                        app:strokeWidth="2dp"
                        app:icon="@drawable/ic_color_picker_custom"
                        app:iconTint="@null"
                        app:iconSize="22dp"
                        app:iconGravity="textStart"
                        android:padding="0dp"
                        app:iconPadding="0dp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Panel Background" android:textColor="#FFFFFF" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickBg"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner50"
                        android:backgroundTint="#E61A1C1E"
                        app:strokeColor="#4DFFFFFF"
                        app:strokeWidth="2dp"
                        app:icon="@drawable/ic_color_picker_custom"
                        app:iconTint="@null"
                        app:iconSize="22dp"
                        app:iconGravity="textStart"
                        android:padding="0dp"
                        app:iconPadding="0dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="16dp" />

                <Switch android:id="@+id/switchTools" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Show Tools Section" android:textColor="#FFFFFF" android:thumbTint="#FFFFFF" />
                <Switch android:id="@+id/switchHideBg" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Invisible Background" android:textColor="#FFFFFF" android:thumbTint="#FFFFFF" />

                <Button
                    android:id="@+id/btnResetUIColors"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#33FFFFFF"
                    android:text="Reset UI Colors"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:cornerRadius="8dp" />

                <Button android:id="@+id/btnGoPremium" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="16dp" android:text="Unlock Full Version" android:textAllCaps="false" android:backgroundTint="@color/accent_blue" app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Reset Button -->
        <Button
            android:id="@+id/btnResetDefaults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset all to Defaults"
            android:backgroundTint="#0DFFFFFF"
            android:textColor="#80FFFFFF"
            android:textAllCaps="false"
            app:cornerRadius="16dp"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</ScrollView>
