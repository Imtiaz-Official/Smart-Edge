<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <!-- Highlight view kept as invisible placeholder so ViewHolder reference stays valid -->
    <View
        android:id="@+id/vPickerBgHighlight"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <ImageView
            android:id="@+id/ivPickerAppIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tvPickerAppName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:textColor="#D9FFFFFF"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- Plus icon - plain, no background/shadow -->
    <ImageView
        android:id="@+id/ivPickerCheck"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="4dp"
        android:padding="4dp"
        android:src="@drawable/ic_plus_custom"
        android:tint="#FFFFFF"
        android:visibility="gone" />

</FrameLayout>
