<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pickerPanelCard"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical"
    android:background="@drawable/bg_panel"
    android:elevation="40dp"
    android:orientation="vertical"
    android:paddingTop="20dp"
    android:paddingBottom="12dp"
    android:paddingHorizontal="20dp">

    <!-- Header Section (Search + Settings) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Pill-shaped Search Bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#26FFFFFF"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#80FFFFFF" />

            <EditText
                android:id="@+id/etPickerSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Search"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#66FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Settings Icon -->
        <ImageButton
            android:id="@+id/btnPickerClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#26FFFFFF"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="#B3FFFFFF" />
    </LinearLayout>

    <!-- Category Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-medium"
        android:text="All small window apps"
        android:textColor="#FFFFFF"
        android:textSize="15sp" />

    <!-- 3-Column Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPickerGrid"
        android:layout_width="match_parent"
        android:layout_height="480dp"
        android:clipToPadding="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbars="vertical" />

</LinearLayout>