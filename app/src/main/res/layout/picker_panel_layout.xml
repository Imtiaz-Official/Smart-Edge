<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pickerPanelCard"
    android:layout_width="210dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/bg_picker_panel"
    android:elevation="24dp"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Compact Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#331A1C1E"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#80FFFFFF" />

            <EditText
                android:id="@+id/etPickerSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Search"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#66FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Settings Icon -->
        <ImageButton
            android:id="@+id/btnPickerClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#331A1C1E"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="#B3FFFFFF" />
    </LinearLayout>

    <!-- Category Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-medium"
        android:text="Choose Apps"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <!-- Grid with fixed max height -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPickerGrid"
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:clipToPadding="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbars="vertical" />

</LinearLayout>