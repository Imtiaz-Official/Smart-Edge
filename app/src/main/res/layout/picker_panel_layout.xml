<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pickerPanelCard"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/bg_picker_panel"
    android:elevation="24dp"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Modern Header Dashboard -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Modern Search Capsule -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#1AFFFFFF"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#80FFFFFF" />

            <EditText
                android:id="@+id/etPickerSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:hint="Search Smart Edge..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#66FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Settings Cog - Pill Shape -->
        <ImageButton
            android:id="@+id/btnPickerClose"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#1AFFFFFF"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_settings"
            android:tint="#B3FFFFFF" />
    </LinearLayout>

    <!-- Header Stats/Actions Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPickerHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="All Apps"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:alpha="0.8" />

        <!-- Edit/Done Toggle Chip -->
        <TextView
            android:id="@+id/btnPickerEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#1AFFFFFF"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="EDIT"
            android:textColor="#4A9EFF"
            android:textSize="11sp"
            android:textAllCaps="true" />
    </LinearLayout>

    <!-- Grid with fixed max height -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPickerGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbars="vertical" />

</LinearLayout>
