<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:padding="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutCardBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_close_btn"
        android:backgroundTint="#0DFFFFFF"
        android:padding="8dp">

        <!-- App Icon Circle -->
        <FrameLayout
            android:id="@+id/frameIconCircle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivPickerAppIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:scaleType="centerInside" />

        </FrameLayout>

        <!-- App Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/frameIconCircle"
            app:layout_constraintEnd_toStartOf="@id/ivPickerCheck"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvPickerAppName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPickerPackageName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Selection Dot -->
        <View
            android:id="@+id/ivPickerCheck"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#4A9EFF"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Background highlight for selected state -->
        <View
            android:id="@+id/vPickerBgHighlight"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#1A4A9EFF"
            android:visibility="gone" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
